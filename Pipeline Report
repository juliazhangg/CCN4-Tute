    print("SECTION 3: Maximum-Likelihood Fitting with PyTorch")
    print("=" * 70)

    df = pd.read_csv(DATA_PATH)

    # Get participants with 150-trial blocks
    participant_blocks = (
        df.groupby(["s_id", "block"])
        .size()
