# SECTION 4: RL-ANN (Neural Network Q-Learning) & Comparison
# =============================================================================

class RLANN(nn.Module):
    def __init__(self, hidden_size=32):
        super().__init__()
        # Reward MLP: [Q(a), r] -> Q_new(a)
        self.reward_w1 = nn.Parameter(torch.randn(hidden_size, 2) * 0.1)
        self.reward_b1 = nn.Parameter(torch.zeros(hidden_size))
        self.reward_w2 = nn.Parameter(torch.randn(1, hidden_size) * 0.1)
        self.reward_b2 = nn.Parameter(torch.zeros(1))

        # Action-history MLP: one-hot(a) -> c (size 4)
        self.action_w1 = nn.Parameter(torch.randn(hidden_size, 4) * 0.1)
        self.action_b1 = nn.Parameter(torch.zeros(hidden_size))
        self.action_w2 = nn.Parameter(torch.randn(4, hidden_size) * 0.1)
        self.action_b2 = nn.Parameter(torch.zeros(4))

        # Forgetting parameter and initial Q-value
        self.f_raw = nn.Parameter(torch.tensor(-2.0))  # sigmoid -> small f
        self.q_init = nn.Parameter(torch.tensor(0.5))

    def forward(self, actions, rewards):
        T = len(actions)
        Q = self.q_init.expand(4).clone()
        nll = torch.tensor(0.0)

        for t in range(T):
            # Action-history module (perseveration)
            if t > 0:
                a_onehot = torch.zeros(4)
                a_onehot[actions[t - 1]] = 1.0
                s_a = torch.tanh(F.linear(a_onehot, self.action_w1, self.action_b1))
                c = F.linear(s_a, self.action_w2, self.action_b2)
            else:
                c = torch.zeros(4)

            # Combine and compute log probabilities
            h = Q + c
            log_probs = F.log_softmax(h, dim=0)
            nll = nll - log_probs[actions[t]]

            # Reward module: update Q for chosen action
            inp = torch.stack([Q[actions[t]], rewards[t]])
            s_r = torch.tanh(F.linear(inp, self.reward_w1, self.reward_b1))
            new_q = F.linear(s_r, self.reward_w2, self.reward_b2).squeeze()

            Q = Q.clone()
            Q[actions[t]] = new_q

            # Forgetting: decay all Q-values toward q_init
            f = torch.sigmoid(self.f_raw)
            Q = (1 - f) * Q + f * self.q_init

        return nll


def fit_participant_rlann(actions, rewards, n_steps=1000, lr=1e-3, weight_decay=1e-4):
    """Fit RL-ANN model to one participant's data."""
    model = RLANN(hidden_size=32)
    optimizer = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=weight_decay)

    actions_t = torch.tensor(actions, dtype=torch.long)
    rewards_t = torch.tensor(rewards, dtype=torch.float32)

    loss_history = []
    for step in range(n_steps):
        optimizer.zero_grad()
        loss = model(actions_t, rewards_t)
        loss.backward()
        optimizer.step()
        loss_history.append(loss.item())

    return loss_history


def section_4(selected_pids):
    print("=" * 70)
    print("SECTION 4: RL-ANN Model & Comparison")
    print("=" * 70)

    df = pd.read_csv(DATA_PATH)

    # Use same 5 example participants as section 3
    example_pids = selected_pids[:5]

    ql_losses = {}
    ann_losses = {}

    for i, pid in enumerate(example_pids):
        sub = df[df["s_id"] == pid]
        block_counts = sub.groupby("block").size()
        block_id = block_counts[block_counts == 150].index[0]
        block_data = sub[sub["block"] == block_id].sort_values("trial_id")

        actions = block_data["action"].values.astype(int)
        rewards = block_data["reward"].values.astype(float)

        print(f"  Fitting participant {pid} ({i + 1}/5)...")

        # Fit Q-learning (refit for fair comparison with same n_steps)
        ql_loss, _ = fit_participant_ql(actions, rewards, n_steps=1000, lr=0.01)
        ql_losses[pid] = ql_loss

        # Fit RL-ANN
        ann_loss = fit_participant_rlann(actions, rewards, n_steps=1000, lr=1e-3)
        ann_losses[pid] = ann_loss

    # Plot comparison
    fig, axes = plt.subplots(1, 5, figsize=(20, 4), sharey=True)
    for idx, pid in enumerate(example_pids):
        ax = axes[idx]
        ax.plot(ql_losses[pid], label="Q-Learning", alpha=0.8, color="#377eb8")
        ax.plot(ann_losses[pid], label="RL-ANN", alpha=0.8, color="#e41a1c")
        ax.set_xlabel("Step")
        ax.set_title(f"P{pid}")
        if idx == 0:
            ax.set_ylabel("Negative Log-Likelihood")
            ax.legend(fontsize=8)

    plt.suptitle("Loss Curves: Q-Learning vs RL-ANN", fontsize=14)
    plt.tight_layout()
    plt.savefig("plot_4_nn_comparison.png", dpi=150)
    plt.close()
    print("Saved: plot_4_nn_comparison.png")

    # Compute final NLL per trial for comparison
    print("\n  Final NLL per trial (lower is better):")
    print(f"  {'PID':<10} {'Q-Learning':<15} {'RL-ANN':<15} {'RL-ANN better?'}")
    for pid in example_pids:
        ql_final = ql_losses[pid][-1] / 150
        ann_final = ann_losses[pid][-1] / 150
        better = "Yes" if ann_final < ql_final else "No"
        print(f"  P{pid:<9} {ql_final:<15.4f} {ann_final:<15.4f} {better}")


