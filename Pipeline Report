# SECTION 3: Maximum-Likelihood Fitting with PyTorch
# =============================================================================

class QLearningModel(nn.Module):
    def __init__(self):
        super().__init__()
        self.alpha_raw = nn.Parameter(torch.tensor(0.0))
        self.kappa_raw = nn.Parameter(torch.tensor(0.0))
        self.beta_raw = nn.Parameter(torch.tensor(1.0))

    @property
    def alpha(self):
        return torch.sigmoid(self.alpha_raw)

    @property
    def kappa(self):
        return torch.tanh(self.kappa_raw)

    @property
    def beta(self):
        return F.softplus(self.beta_raw)

    def forward(self, actions, rewards):
        T = len(actions)
        Q = torch.full((4,), 0.8)
        c = torch.zeros(4)
        nll = torch.tensor(0.0)

        for t in range(T):
            h = Q + c
            log_probs = F.log_softmax(self.beta * h, dim=0)
            nll = nll - log_probs[actions[t]]

            # Update Q for chosen action
            Q = Q.clone()
            delta = self.alpha * (rewards[t] - Q[actions[t]])
            Q[actions[t]] = Q[actions[t]] + delta

            # Update perseveration
            c = torch.zeros(4)
            c[actions[t]] = self.kappa

        return nll


def fit_participant_ql(actions, rewards, n_steps=500, lr=0.01):
    """Fit Q-learning model to one participant's data. Returns loss history and fitted params."""
    model = QLearningModel()
    optimizer = torch.optim.Adam(model.parameters(), lr=lr)

    actions_t = torch.tensor(actions, dtype=torch.long)
    rewards_t = torch.tensor(rewards, dtype=torch.float32)

    loss_history = []
    for step in range(n_steps):
        optimizer.zero_grad()
        loss = model(actions_t, rewards_t)
        loss.backward()
        optimizer.step()
        loss_history.append(loss.item())

    params = {
        "alpha": model.alpha.item(),
        "kappa": model.kappa.item(),
        "beta": model.beta.item(),
    }
    return loss_history, params


