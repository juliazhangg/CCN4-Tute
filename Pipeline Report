def softmax(x):
    x = x - np.max(x)
    e = np.exp(x)
    return e / e.sum()


def run_q_learning_on_schedule(payouts, alpha, kappa, beta, q_init=0.8):
    """
    Run simplified Q-learning model on a reward schedule.
    payouts: array of shape (T, 4) — available rewards for each action on each trial
    Returns: total reward collected
    """
    T = payouts.shape[0]
    Q = np.full(4, q_init)
    c = np.zeros(4)
    total_reward = 0.0

    for t in range(T):
        # Compute choice probabilities
        h = Q + c
        p = softmax(beta * h)

        # Sample action
        action = np.random.choice(4, p=p)

        # Get reward from the schedule
        reward = payouts[t, action]
        total_reward += reward

        # Update Q-value for chosen action (eq 1)
        Q[action] = Q[action] + alpha * (reward - Q[action])

        # Update perseveration (eq 4)
        c = np.zeros(4)
        c[action] = kappa

    return total_reward


def section_2():
    print("=" * 70)
    print("SECTION 2: Q-Learning Model & Reward Box Plot")
    print("=" * 70)

    df = pd.read_csv(DATA_PATH)

    # Get 10 different reward schedules (150-trial blocks)
    participant_blocks = (
        df.groupby(["s_id", "block"])
        .size()
        .reset_index(name="n_trials")
    )
    long_blocks = participant_blocks[participant_blocks["n_trials"] == 150]
    selected = long_blocks.sample(n=10, random_state=42)

    schedules = []
    for _, row in selected.iterrows():
        block_data = df[(df["s_id"] == row["s_id"]) & (df["block"] == row["block"])]
        block_data = block_data.sort_values("trial_id")
        payouts = block_data[["payout_1", "payout_2", "payout_3", "payout_4"]].values
        schedules.append(payouts)

    # Define parameter settings (good and bad)
    param_settings = [
        {"alpha": 0.5,  "kappa": 0.1,  "beta": 6.0,  "label": "Good\na=0.5 k=0.1 b=6"},
        {"alpha": 0.3,  "kappa": 0.05, "beta": 8.0,  "label": "Good\na=0.3 k=0.05 b=8"},
        {"alpha": 0.2,  "kappa": 0.2,  "beta": 4.0,  "label": "Medium\na=0.2 k=0.2 b=4"},
        {"alpha": 0.05, "kappa": 0.0,  "beta": 2.0,  "label": "Medium\na=0.05 k=0 b=2"},
        {"alpha": 0.01, "kappa": 0.0,  "beta": 0.5,  "label": "Bad\na=0.01 k=0 b=0.5"},
        {"alpha": 0.5,  "kappa": 0.9,  "beta": 1.0,  "label": "Bad\na=0.5 k=0.9 b=1"},
    ]

    # Run simulations
    n_runs = 5
    all_rewards = {s["label"]: [] for s in param_settings}

    for params in param_settings:
        for schedule in schedules:
            for _ in range(n_runs):
                total = run_q_learning_on_schedule(
                    schedule, params["alpha"], params["kappa"], params["beta"]
                )
                all_rewards[params["label"]].append(total * 100)  # Scale to points

    # Compute chance-level reward (random policy)
    chance_rewards = []
    for schedule in schedules:
        for _ in range(n_runs):
            total = sum(schedule[t, np.random.choice(4)] for t in range(150))
            chance_rewards.append(total * 100)
    chance_mean = np.mean(chance_rewards)

    # Box plot
    fig, ax = plt.subplots(figsize=(12, 6))
    labels = list(all_rewards.keys())
    data = [all_rewards[l] for l in labels]
    bp = ax.boxplot(data, labels=labels, patch_artist=True)

    box_colors = ["#2ca02c", "#2ca02c", "#ff7f0e", "#ff7f0e", "#d62728", "#d62728"]
    for patch, color in zip(bp["boxes"], box_colors):
        patch.set_facecolor(color)
        patch.set_alpha(0.6)

    ax.axhline(chance_mean, color="gray", linestyle="--", alpha=0.7, label="Chance level")
    ax.set_ylabel("Total Reward (points over 150 trials)")
    ax.set_title("Q-Learning Model Performance Across Parameter Settings")
    ax.legend()
    plt.xticks(fontsize=8)
    plt.tight_layout()
    plt.savefig("plot_2_model_rewards.png", dpi=150)
    plt.close()
    print("Saved: plot_2_model_rewards.png")


